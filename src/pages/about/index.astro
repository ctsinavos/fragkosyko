---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations, getLocalizedPath, type Lang } from '../../i18n/translations';

const lang: Lang = 'el';
const t = useTranslations(lang);
---

<Layout title={t('about.meta.title')} description={t('about.meta.description')}>
  <Header />

  <section class="py-20 bg-gradient-to-br from-warm-sand/30 to-sea-teal/10">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-5xl md:text-6xl font-serif font-bold text-garden-green mb-6">{t('about.hero.title')}</h1>
      <p class="text-lg max-w-3xl mx-auto text-charcoal/80">{t('about.hero.subtitle')}</p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto prose prose-lg">
        <p class="text-lg leading-relaxed mb-6">{t('about.story.p1')}</p>
        <p class="text-lg leading-relaxed mb-6">{t('about.story.p2')}</p>
        <p class="text-lg leading-relaxed mb-6">{t('about.story.p3')}</p>
        <p class="text-lg leading-relaxed mb-6">{t('about.story.p4')}</p>
        <p class="text-lg leading-relaxed">{t('about.story.p5')}</p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-gradient-to-br from-warm-sand/20 to-sea-teal/10">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-4xl font-serif font-bold text-center mb-4 text-garden-green">{t('about.team.title')}</h2>
        <p class="text-center text-lg text-charcoal/70 mb-14">{t('about.team.subtitle')}</p>
        <div class="flex flex-col gap-10">

          <!-- Member 1 -->
          <div class="bg-white rounded-3xl shadow-lg hover:shadow-xl transition-shadow overflow-hidden flex flex-col md:flex-row">
            <div class="md:w-64 w-full flex-shrink-0">
              <img src="/team/dimitris_molindris.jpg" alt={t('about.team.member1.name')} class="w-full h-64 md:h-full object-cover" />
            </div>
            <div class="flex-1 p-8 flex flex-col justify-center">
              <div class="mb-4">
                <h3 class="text-2xl font-serif font-bold text-garden-green">{t('about.team.member1.name')}</h3>
                <p class="text-sm text-sea-teal font-semibold mt-1">{t('about.team.member1.role')}</p>
              </div>
              <div class="h-px bg-warm-sand mb-4"></div>
              <p class="text-sm text-charcoal/80 leading-relaxed mb-3">{t('about.team.member1.bio')}</p>
              <p class="text-sm text-charcoal/80 leading-relaxed">{t('about.team.member1.bio2')}</p>
            </div>
          </div>

          <!-- Member 2 -->
          <div class="bg-white rounded-3xl shadow-lg hover:shadow-xl transition-shadow overflow-hidden flex flex-col md:flex-row-reverse">
            <div class="md:w-64 w-full flex-shrink-0">
              <img src="/team/christos_lagios.jpg" alt={t('about.team.member2.name')} class="w-full h-64 md:h-full object-cover" />
            </div>
            <div class="flex-1 p-8 flex flex-col justify-center">
              <div class="mb-4">
                <h3 class="text-2xl font-serif font-bold text-garden-green">{t('about.team.member2.name')}</h3>
                <p class="text-sm text-sea-teal font-semibold mt-1">{t('about.team.member2.role')}</p>
              </div>
              <div class="h-px bg-warm-sand mb-4"></div>
              <p class="text-sm text-charcoal/80 leading-relaxed mb-3">{t('about.team.member2.bio')}</p>
              <p class="text-sm text-charcoal/80 leading-relaxed mb-3">{t('about.team.member2.bio2')}</p>
              <p class="text-sm text-charcoal/80 leading-relaxed">{t('about.team.member2.bio3')}</p>
            </div>
          </div>

          <!-- Member 3 -->
          <div class="bg-white rounded-3xl shadow-lg hover:shadow-xl transition-shadow overflow-hidden flex flex-col md:flex-row">
            <div class="md:w-64 w-full flex-shrink-0">
              <img src="/team/christos_oikonomou.jpg" alt={t('about.team.member3.name')} class="w-full h-64 md:h-full object-cover" />
            </div>
            <div class="flex-1 p-8 flex flex-col justify-center">
              <div class="mb-4">
                <h3 class="text-2xl font-serif font-bold text-garden-green">{t('about.team.member3.name')}</h3>
                <p class="text-sm text-sea-teal font-semibold mt-1">{t('about.team.member3.role')}</p>
              </div>
              <div class="h-px bg-warm-sand mb-4"></div>
              <p class="text-sm text-charcoal/80 leading-relaxed mb-3">{t('about.team.member3.bio')}</p>
              <p class="text-sm text-charcoal/80 leading-relaxed">{t('about.team.member3.bio2')}</p>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- Experience Our Garden CTA -->
  <section class="py-20 bg-garden-green text-cycladic-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-4xl md:text-5xl font-serif font-bold mb-4">{t('about.experience.title')}</h2>
      <p class="text-lg text-cycladic-white/80 mb-8 max-w-2xl mx-auto">{t('about.experience.subtitle')}</p>
      <a href={getLocalizedPath('/reservations', lang)} class="inline-block px-8 py-4 bg-cycladic-white text-garden-green rounded-full hover:bg-warm-sand transition-all font-semibold text-lg shadow-lg">{t('about.experience.cta')}</a>
    </div>
  </section>

  <Footer />
</Layout>

